---
import Layout from '../layouts/Layout.astro';
import TerminalChrome from '../components/TerminalChrome.astro';
import CommandLabel from '../components/CommandLabel.astro';
import {
	profile,
	about,
	stack,
	projects,
	education,
} from '../data/site';

import AstroIcon from '../icons/Astro.astro';
import TypeScriptIcon from '../icons/TypeScript.astro';
import JavaScriptIcon from '../icons/JavaScript.astro';
import JavaIcon from '../icons/Java.astro';
import CIcon from '../icons/C.astro';
import Html5Icon from '../icons/Html5.astro';
import Css3Icon from '../icons/Css3.astro';
import GitIcon from '../icons/Git.astro';

const stackIcons: Record<string, typeof AstroIcon> = {
	Astro: AstroIcon,
	TypeScript: TypeScriptIcon,
	JavaScript: JavaScriptIcon,
	Java: JavaIcon,
	C: CIcon,
	HTML5: Html5Icon,
	CSS3: Css3Icon,
	Git: GitIcon,
};

const langColor: Record<string, string> = {
	Astro: 'text-lang-astro border-lang-astro/40 bg-lang-astro/10',
	TypeScript: 'text-lang-ts border-lang-ts/40 bg-lang-ts/10',
	JavaScript: 'text-lang-js border-lang-js/40 bg-lang-js/10',
};
---

<Layout>
	<!-- Fondo de rejilla fijo detrás de todo el contenido -->
	<div class="pointer-events-none fixed inset-0 -z-10 bg-terminal">
		<div
			class="absolute inset-0 bg-[linear-gradient(to_right,#4f4f4f2e_1px,transparent_1px),linear-gradient(to_bottom,#4f4f4f2e_1px,transparent_1px)] bg-size-[14px_24px]"
		>
		</div>
	</div>

	<div class="min-h-screen">
		<TerminalChrome />

		<main class="mx-auto max-w-5xl px-5 py-12 sm:px-8 sm:py-16">
			<!-- ══════════════ HERO ══════════════ -->
			<section id="hero" class="scroll-mt-28 text-center">
				<p class="text-sm sm:text-base">
					<span class="text-accent">daniel@portfolio</span><span class="text-muted"
						> ~$</span
					>{' '}<span class="text-prompt">whoami</span><span class="cursor"></span>
				</p>

				<h1
					class="reveal mt-5 text-4xl font-extrabold tracking-tight text-ink sm:text-6xl"
				>
					{profile.name}
				</h1>

				<p class="reveal mt-3 text-lg text-accent sm:text-xl">
					<span class="text-prompt">&gt;</span> {profile.role}
				</p>

				<p class="reveal mx-auto mt-5 max-w-2xl leading-relaxed text-muted">
					{profile.tagline}
				</p>

				<div class="reveal mt-8 flex flex-wrap justify-center gap-3">
					<a
						href={profile.github}
						target="_blank"
						rel="noopener noreferrer"
						class="rounded-md bg-accent-strong px-4 py-2.5 text-sm font-medium text-white transition-transform hover:-translate-y-0.5 hover:bg-accent focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
					>
						./github --open
					</a>
					<a
						href={profile.linkedin}
						target="_blank"
						rel="noopener noreferrer"
						class="rounded-md border border-line px-4 py-2.5 text-sm text-ink transition-colors hover:border-accent hover:text-accent focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
					>
						./linkedin
					</a>
					<a
						href="#contacto"
						class="rounded-md border border-line px-4 py-2.5 text-sm text-ink transition-colors hover:border-accent hover:text-accent focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
					>
						./contacto
					</a>
				</div>
			</section>

			<!-- ══════════════ SOBRE MÍ ══════════════ -->
			<section class="mt-20">
				<p id="sobre-mi" class="mb-4 text-sm text-prompt scroll-mt-28">
					/* sobre-mi.md */
				</p>
				<div
					class="reveal rounded-lg border border-line bg-surface p-6 sm:p-8"
				>
					<ul class="space-y-4">
						{
							about.map((line) => (
								<li class="flex gap-3 leading-relaxed text-ink/90">
									<span class="mt-0.5 text-accent" aria-hidden="true">
										&#9656;
									</span>
									<span>{line}</span>
								</li>
							))
						}
					</ul>
				</div>
			</section>

			<!-- ══════════════ STACK ══════════════ -->
			<section class="mt-20">
				<CommandLabel id="stack" command="cat stack.json" />
				<ul class="grid grid-cols-4 gap-3 sm:gap-4 md:grid-cols-8">
					{
						stack.map((tech) => {
							const Icon = stackIcons[tech];
							return (
								<li class="reveal flex flex-col items-center gap-2.5 rounded-lg border border-line bg-surface p-4 transition-all hover:-translate-y-1 hover:border-accent/60 hover:bg-surface-hover">
									{Icon && <Icon class="h-9 w-9" aria-hidden="true" />}
									<span class="text-xs text-muted">{tech}</span>
								</li>
							);
						})
					}
				</ul>
			</section>

			<!-- ══════════════ PROYECTOS ══════════════ -->
			<section class="mt-20">
				<CommandLabel id="proyectos" command="ls ./proyectos --github" />
				<div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
					{
						projects.map((project) => (
							<a
								href={project.url}
								target="_blank"
								rel="noopener noreferrer"
								class="reveal group flex flex-col rounded-lg border border-line bg-surface p-5 transition-all hover:-translate-y-1 hover:border-accent/60 hover:bg-surface-hover focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
							>
								<div class="flex items-center justify-between gap-3">
									<h3 class="font-bold text-ink group-hover:text-accent">
										{project.name}
									</h3>
									<span
										class={`shrink-0 rounded-full border px-2 py-0.5 text-[0.7rem] ${langColor[project.lang]}`}
									>
										{project.lang}
									</span>
								</div>
								<p class="mt-3 text-sm leading-relaxed text-muted">
									{project.description}
								</p>
							</a>
						))
					}
				</div>
			</section>

			<!-- ══════════════ EDUCACIÓN ══════════════ -->
			<section class="mt-20">
				<CommandLabel id="educacion" command="cat educacion.log" />
				<div class="space-y-4">
					{
						education.map((edu) => (
							<div class="reveal flex flex-col gap-4 rounded-lg border border-line bg-surface p-6 sm:flex-row sm:items-center sm:justify-between sm:p-8">
								<div>
									<h3 class="font-bold text-ink">{edu.title}</h3>
									<p class="mt-1 text-sm text-muted">{edu.place}</p>
								</div>
								<span
									class={`w-fit shrink-0 rounded-full border px-3 py-1 text-xs ${
										edu.current
											? 'border-prompt/40 bg-prompt/10 text-prompt'
											: 'border-line text-muted'
									}`}
								>
									{edu.status}
								</span>
							</div>
						))
					}
				</div>
			</section>

			<!-- ══════════════ CONTACTO ══════════════ -->
			<section class="mt-20">
				<hr class="border-line" />
				<div class="mt-10">
					<CommandLabel id="contacto" command="./contacto --send" />
					<div class="flex flex-wrap gap-3">
						<a
							href={`mailto:${profile.email}`}
							class="rounded-md bg-accent-strong px-4 py-2.5 text-sm font-medium text-white transition-transform hover:-translate-y-0.5 hover:bg-accent focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
						>
							Escríbeme un email &rarr;
						</a>
						<a
							href={profile.github}
							target="_blank"
							rel="noopener noreferrer"
							class="rounded-md border border-line px-4 py-2.5 text-sm text-ink transition-colors hover:border-accent hover:text-accent focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
						>
							GitHub
						</a>
						<a
							href={profile.linkedin}
							target="_blank"
							rel="noopener noreferrer"
							class="rounded-md border border-line px-4 py-2.5 text-sm text-ink transition-colors hover:border-accent hover:text-accent focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
						>
							LinkedIn
						</a>
					</div>
				</div>
			</section>

			<footer class="mt-20 border-t border-line pt-6 text-xs text-muted">
				<p>
					<span class="text-prompt">daniel@portfolio</span><span> ~$</span> echo
					"© {new Date().getFullYear()} {profile.name} — hecho con Astro"
				</p>
			</footer>
		</main>
	</div>
</Layout>

<script>
	// Revela elementos al entrar en el viewport
	const items = document.querySelectorAll('.reveal');
	if ('IntersectionObserver' in window) {
		const io = new IntersectionObserver(
			(entries) => {
				for (const entry of entries) {
					if (entry.isIntersecting) {
						entry.target.classList.add('is-visible');
						io.unobserve(entry.target);
					}
				}
			},
			{ threshold: 0.12 },
		);
		items.forEach((el) => io.observe(el));
	} else {
		items.forEach((el) => el.classList.add('is-visible'));
	}
</script>
