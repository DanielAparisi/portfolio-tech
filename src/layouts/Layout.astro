---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Daniel Aparisi — Desarrollador junior',
	description = 'Portfolio de Daniel Aparisi, estudiante de Ingeniería de Software en la UPM. Aprendiendo y construyendo con Astro, TypeScript y Java.',
} = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />

		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="author" content="Daniel Aparisi" />
		<meta name="theme-color" content="#0d1117" />

		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta name="twitter:card" content="summary_large_image" />

	</head>
	<body>
		<slot />
	</body>
</html>
