---
import '../styles/global.css';
// URL con hash del subset latin de la fuente, para precargarlo.
// Debe ser el mismo archivo que referencia el CSS de fontsource:
// así el preload se reutiliza en vez de descargar dos veces.
import fontLatin from '@fontsource-variable/jetbrains-mono/files/jetbrains-mono-latin-wght-normal.woff2?url';
import { getAbsoluteLocaleUrl } from 'astro:i18n';
import { profile, stack, ui, type Locale } from '../data/site';

interface Props {
	title?: string;
	description?: string;
	locale?: Locale;
}

const {
	locale = 'es',
	title = ui[locale ?? 'es'].metaTitle,
	description = ui[locale ?? 'es'].metaDescription,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL('/og.png', Astro.site);
const ogImageAlt = {
	es: 'Terminal con el prompt whoami mostrando: Daniel Aparisi, estudiante de Ingeniería de Software en la UPM',
	en: 'Terminal with the whoami prompt showing: Daniel Aparisi, Software Engineering student at UPM',
}[locale];

// Datos estructurados Schema.org: describen la página como el perfil
// de una persona-entidad (nombre, rol, estudios, enlaces verificados).
// Es lo que consumen Google y los motores de IA para "saber quién eres".
// Nota CSP: los bloques ld+json son datos, no se ejecutan como script,
// así que la política script-src 'self' no los bloquea.
const schema = {
	'@context': 'https://schema.org',
	'@type': 'ProfilePage',
	url: canonical.href,
	inLanguage: locale,
	mainEntity: {
		'@type': 'Person',
		'@id': new URL('/#person', Astro.site).href,
		name: profile.name,
		jobTitle: profile.role[locale],
		description: profile.tagline[locale],
		url: getAbsoluteLocaleUrl(locale, ''),
		image: ogImage.href,
		email: `mailto:${profile.email}`,
		sameAs: [profile.github, profile.linkedin, profile.fiverr],
		knowsAbout: stack,
		alumniOf: [
			{
				'@type': 'CollegeOrUniversity',
				name: 'Universidad Politécnica de Madrid',
			},
			{ '@type': 'CollegeOrUniversity', name: 'Universidad de Alcalá' },
		],
		memberOf: {
			'@type': 'Organization',
			name:
				locale === 'es'
					? 'Asociación de Ciberseguridad de la UPM'
					: 'UPM Cybersecurity Association',
		},
	},
};
---

<!doctype html>
<html lang={locale}>
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<link
			rel="preload"
			as="font"
			type="font/woff2"
			href={fontLatin}
			crossorigin
		/>

		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="author" content="Daniel Aparisi" />
		<meta name="robots" content="index, follow, max-image-preview:large" />
		<meta name="theme-color" content="#0d1117" />
		<link rel="canonical" href={canonical} />

		<!-- Versiones por idioma: mismo contenido en / (es) y /en/ -->
		<link rel="alternate" hreflang="es" href={getAbsoluteLocaleUrl('es', '')} />
		<link rel="alternate" hreflang="en" href={getAbsoluteLocaleUrl('en', '')} />
		<link
			rel="alternate"
			hreflang="x-default"
			href={getAbsoluteLocaleUrl('es', '')}
		/>

		<!-- Open Graph -->
		<meta property="og:type" content="profile" />
		<meta property="og:site_name" content="Daniel Aparisi — Portfolio" />
		<meta property="og:url" content={canonical} />
		<meta property="og:locale" content={locale === 'es' ? 'es_ES' : 'en_US'} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImage} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:alt" content={ogImageAlt} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImage} />

		<!-- Datos estructurados (Schema.org) -->
		<script
			is:inline
			type="application/ld+json"
			set:html={JSON.stringify(schema)}
		/>
	</head>
	<body>
		<slot />
	</body>
</html>
